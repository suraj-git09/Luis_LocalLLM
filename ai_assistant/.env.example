# Online LLM (used when local Ollama is not running)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Local LLM (Ollama)
# Must match a model you have pulled: run `ollama list` to check
LOCAL_MODEL=gemma2:2b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Application
LOG_LEVEL=INFO
DATA_DIR=data
VOSK_MODEL_DIR=data/vosk-model-small-en-us-0.15
WHISPER_MODEL_SIZE=tiny

# Voice
TTS_RATE=175
TTS_VOLUME=1.0
WAKE_WORD=assistant

# Security limits
MAX_INPUT_CHARS=2000
MAX_NOTE_CHARS=500
MAX_REMINDER_CHARS=300
MAX_MEMORY_MESSAGES=8
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=256
LLM_RATE_LIMIT_CALLS=10
LLM_RATE_LIMIT_PERIOD=60

# Logging
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# Google Sign-In has been removed from the app (no longer offered in login/signup).
# The GOOGLE_CLIENT_ID and related code/endpoints are no longer used.
# You may safely delete or ignore this variable.
# GOOGLE_CLIENT_ID=...

# -----------------------------------------------------------------------------
# Email / OTP verification (for /api/auth/signup + verify-otp flow)
# -----------------------------------------------------------------------------
# The backend sends 6-digit codes via Gmail SMTP when users create an account.
#
# REQUIRED for real emails to reach users:
#   1. Turn on 2-Step Verification for the Gmail account.
#   2. Create an "App password" here: https://myaccount.google.com/apppasswords
#   3. Use the 16-character password below (remove any spaces).
#
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=abcdwxyzabcdwxyz
#
# Behavior when GMAIL_USER / GMAIL_APP_PASSWORD are NOT set (or empty):
#   - OTP is generated and stored (in-memory, 10 min expiry).
#   - Server prints/logs the code:  === [DEV] OTP for user@example.com: 123456 ===
#   - The signup API response includes "dev_code".
#   - Web UI and Android app will display the code on the verification screen
#     and often pre-fill it automatically (great for local dev / testing with friends).
#
# For any real deployment or when giving the app to other people, you MUST set
# the two GMAIL_* variables so that actual emails arrive in their inboxes.
# Otherwise only the operator of the backend server can see the codes.
# -----------------------------------------------------------------------------